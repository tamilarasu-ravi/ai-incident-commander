# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...

# LLM — primary: OpenAI, fallback: Google Gemini
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1
GOOGLE_API_KEY=...
GOOGLE_MODEL=gemini-2.0-flash

# Database — use host `db` when running via docker compose
DATABASE_URL=postgresql+asyncpg://incident:incident@db:5432/incident_commander

# Integrations
GITHUB_TOKEN=ghp_...
JIRA_API_TOKEN=...
JIRA_BASE_URL=https://your-org.atlassian.net
DATADOG_API_KEY=...
DATADOG_APP_KEY=...
DATADOG_SITE=datadoghq.com

# App
INCIDENTS_CHANNEL_ID=C...
LOG_LEVEL=info
