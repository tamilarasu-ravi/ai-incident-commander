# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...

# LLM — primary: OpenAI, fallback: Google Gemini
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1
GOOGLE_API_KEY=...
GOOGLE_MODEL=gemini-2.0-flash

# Database — use host `db` when running via docker compose
DATABASE_URL=postgresql+asyncpg://incident:incident@db:5432/incident_commander

# GitHub
GITHUB_TOKEN=github_pat_...
GITHUB_REPO_OWNER=your-github-username
GITHUB_REPO_NAME=your-demo-repo

# Jira
JIRA_API_TOKEN=...
JIRA_EMAIL=you@example.com
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_PROJECT_KEY=SCRUM

# Datadog — Japan region example: ap1.datadoghq.com
DATADOG_API_KEY=...
DATADOG_APP_KEY=...
DATADOG_SITE=ap1.datadoghq.com
DATADOG_LOG_INDEX=main

# Evidence collection
EVIDENCE_LOOKBACK_HOURS=2

# App
INCIDENTS_CHANNEL_ID=C...
LOG_LEVEL=info
