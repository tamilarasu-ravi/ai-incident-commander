# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...

# LLM — primary: OpenAI, fallback: Google Gemini
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1
# Optional cheaper model for grounding validation only (falls back to OPENAI_MODEL when unset)
OPENAI_GROUNDING_MODEL=gpt-4.1-mini
GOOGLE_API_KEY=...
GOOGLE_MODEL=gemini-2.0-flash
# Optional cheaper model for grounding validation only (falls back to GOOGLE_MODEL when unset)
GOOGLE_GROUNDING_MODEL=gemini-2.0-flash

# Database — host port must match docker-compose.yml `db.ports` (e.g. 5439:5432)
# - uvicorn on your Mac: use localhost:<host-port>
# - app container via Docker Compose: overridden to host `db` in compose file
DATABASE_URL=postgresql+asyncpg://incident:incident@localhost:5439/incident_commander

# GitHub
GITHUB_TOKEN=github_pat_...
GITHUB_REPO_OWNER=your-github-username
GITHUB_REPO_NAME=your-demo-repo
GITHUB_USE_MCP=true

# Jira
JIRA_API_TOKEN=...
JIRA_EMAIL=you@example.com
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_PROJECT_KEY=SCRUM
JIRA_ISSUE_TYPE=Task

# Datadog — Japan region example: ap1.datadoghq.com
DATADOG_API_KEY=...
DATADOG_APP_KEY=...
DATADOG_SITE=ap1.datadoghq.com
DATADOG_LOG_INDEX=main

# Evidence collection
EVIDENCE_LOOKBACK_HOURS=2
# LLM prompt compaction — tune down to reduce token spend per investigation
EVIDENCE_FIELD_MAX_CHARS=500
EVIDENCE_PROMPT_TOKEN_BUDGET=6000
CHARS_PER_TOKEN_ESTIMATE=4

# App
INCIDENTS_CHANNEL_ID=C...
PAGERDUTY_WEBHOOK_SECRET=...       # required for POST /webhooks/pagerduty
# Set true for hackathon demos — uses fixture evidence for checkout/payment/auth services
DEMO_MODE=true
LOG_LEVEL=info
APP_ENV=development
REQUIRE_POSTGRES_IN_PRODUCTION=true

# Scaling — Phase 1 (in-process queue, ~100 users)
RUN_ASYNC_TIMEOUT_SECONDS=120
MAX_CONCURRENT_INVESTIGATIONS=3
INVESTIGATION_QUEUE_MAX_SIZE=50
INVESTIGATION_WORKER_THREADS=2

# Scaling — Phase 2 (HA, 1000+ org)
SLACK_SOCKET_MODE_ENABLED=true
REDIS_URL=redis://localhost:6379/0
INVESTIGATION_WORKER_ENABLED=true
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Scaling — Phase 3 (resilience)
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_SECONDS=60
EVIDENCE_CACHE_ENABLED=true
EVIDENCE_CACHE_TTL_SECONDS=120
