{
  "display_information": {
    "name": "AI Incident Commander",
    "description": "AI-powered RCA investigation agent for production incidents",
    "background_color": "#1a1a2e"
  },
    "features": {
    "app_home": {
      "home_tab_enabled": false,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "bot_user": {
      "display_name": "Incident Commander",
      "always_online": true
    },
    "assistant_view": {
      "assistant_description": "Investigates production incidents, gathers evidence from GitHub, logs, and Jira, and surfaces a confidence-scored RCA for human approval.",
      "suggested_prompts": [
        {
          "title": "Redis pool exhaustion",
          "message": "checkout-service latency spike"
        },
        {
          "title": "Null deploy regression",
          "message": "payment-service null deploy regression"
        },
        {
          "title": "Flaky test false alarm",
          "message": "auth-service flaky integration test failure"
        }
      ]
    },
    "slash_commands": [
      {
        "command": "/incident",
        "description": "Start an incident investigation for a service",
        "usage_hint": "<service> <description>",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "channels:history",
        "channels:read",
        "chat:write",
        "chat:write.public",
        "commands",
        "groups:history",
        "groups:read",
        "assistant:write",
        "search:read.public",
        "im:history",
        "im:read"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "assistant_thread_started",
        "assistant_thread_context_changed",
        "message.im",
        "message.channels",
        "app_mention"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
